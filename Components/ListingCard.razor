@using RealEstateMinsk.Models
@using RealEstateMinsk.Services

@inject ListingService ListingService
@inject NavigationManager Nav

<style>
    .interesting-btn {
        color: #ccd6dd;
        transition: color 0.2s ease, transform 0.2s ease;
        font-size: 1.2rem;
    }
    .interesting-btn:hover {
        transform: scale(1.2);
    }
    .interesting-btn.active {
        color: #ffac33;
    }
</style>

    <div class="listing-card">
        <div class="d-flex justify-content-between align-items-start">
            <h6 class="mb-1 text-truncate" style="max-width: 70%;">@Listing.Title</h6>
            <i class="bi @(Listing.IsInteresting ? "bi-star-fill active" : "bi-star") interesting-btn" 
               @onclick="ToggleInteresting" style="cursor: pointer;"></i>
        </div>
    <div class="d-flex align-items-center gap-2">
        <div class="price-tag">$@Listing.PriceUsd.ToString("N0")</div>
        @if (Listing.PriceHistories?.Count > 1)
        {
            var history = Listing.PriceHistories.Where(p => p.PriceUsd > 0).OrderBy(p => p.RecordedAt).ToList();
            if (history.Count > 1)
            {
                var firstPrice = history.First().PriceUsd;
                var diff = Listing.PriceUsd - firstPrice;
                if (diff != 0)
                {
                    if (diff < 0)
                    {
                        <span class="badge bg-success" style="font-size: 0.7rem;" title="Было $@firstPrice.ToString("N0")">📉 -$@Math.Abs(diff).ToString("N0")</span>
                    }
                    else
                    {
                        <span class="badge bg-danger" style="font-size: 0.7rem;" title="Было $@firstPrice.ToString("N0")">📈 +$@Math.Abs(diff).ToString("N0")</span>
                    }
                }
            }
        }
    </div>
    <small>@Listing.Area м² • @Listing.Rooms ком • $@Listing.PricePerSqm.ToString("N0")/м²</small>
    <div class="mt-2">
        <span class="badge badge-type">@Listing.FlatType</span>
        <span class="badge badge-district">
            @Listing.District
            @if (Listing.IsDistrictAutoDetected)
            {
                <span title="Район определен автоматически (OSM/Аналитика)">🧭</span>
            }
        </span>
    </div>
    <a href="@Listing.Url" target="_blank" class="btn btn-sm btn-outline-primary mt-2 w-100">
        <i class="bi bi-box-arrow-up-right"></i> Открыть
    </a>
</div>

@code {
    [Parameter] public Listing Listing { get; set; } = null!;

    async Task ToggleInteresting()
    {
        Listing.IsInteresting = !Listing.IsInteresting;
        StateHasChanged();
        await ListingService.ToggleInterestingAsync(Listing.Id);
    }
}