{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "RealEstateMinsk": "Debug"
    }
  },
  "AllowedHosts": "*",
  "DataCollection": {
    "IntervalHours": 6,
    "MaxPagesPerRun": 15,
    "PageDelayMs": 4000,
    "AutoRecalculateScores": true
  },
  "InvestmentAnalysis": {
    "ScoreWeights": {
      "PriceAttractiveness": 0.35,
      "LocationScore": 0.25,
      "GrowthPotential": 0.25,
      "LiquidityScore": 0.15
    },
    "BuyThreshold": 70,
    "HoldThreshold": 50,
    "UndervaluedThreshold": 15,
    "AllowExternalGeoApi": false
  }
}