@page "/listings"
@using RealEstateMinsk.Models
@using RealEstateMinsk.Services

@inject ListingService ListingService
@inject NavigationManager Nav

<PageTitle>Объявления — Минск</PageTitle>

<div class="listings-header">
    <h1>Объявления</h1>
    <div class="search-bar">
        <div class="filter-group">
            <select class="form-select custom-select" @bind="filter.District">
                <option value="">Все районы</option>
                @foreach (var d in districts)
                {
                    <option value="@d">@d</option>
                }
            </select>
            
            <select class="form-select custom-select" @bind="filter.Rooms">
                <option value="0">Комнаты</option>
                <option value="1">1 комната</option>
                <option value="2">2 комнаты</option>
                <option value="3">3 комнаты</option>
                <option value="4">4+ комнаты</option>
            </select>

            <div class="price-range">
                <input type="number" class="form-control" placeholder="От $" @bind="filter.MinPrice">
                <span class="range-dash">—</span>
                <input type="number" class="form-control" placeholder="До $" @bind="filter.MaxPrice">
            </div>

            <button class="btn btn-primary search-btn" @onclick="ApplyFilter">
                <i class="bi bi-search"></i> Найти
            </button>
        </div>
    </div>
</div>

<div class="results-meta">
    Найдено объектов: <strong>@result.TotalCount</strong>
    @if (result.TotalPages > 1)
    {
        <span class="ms-2 text-muted">(Страница @result.Page из @result.TotalPages)</span>
    }
</div>

<div class="listings-grid">
    @foreach (var item in result.Items)
    {
        <div class="listing-card-modern">
            <div class="card-body">
                <div class="card-main">
                    <div class="card-info">
                        <div class="card-top">
                            <h5 class="card-title">@item.Title</h5>
                            <div class="card-badges">
                                <span class="badge-custom type">@item.FlatType</span>
                                <span class="badge-custom district">@item.District</span>
                                <span class="badge-custom rooms">@item.Rooms ком.</span>
                                <span class="badge-custom area">@item.Area м²</span>
                            </div>
                        </div>
                        <p class="card-location"><i class="bi bi-geo-alt"></i> @item.Location</p>
                        
                        <div class="investment-preview">
                            <InvestmentCard Listing="item" ShowForecast="false" />
                        </div>
                    </div>
                    
                    <div class="card-actions">
                        <div class="price-info">
                            <div class="main-price">$@item.PriceUsd.ToString("N0")</div>
                            <div class="sqm-price">$@item.PricePerSqm.ToString("N0")/м²</div>
                        </div>
                        
                        <div class="btn-group-vertical w-100 mt-3">
                            <a href="@item.Url" target="_blank" class="btn btn-outline-primary btn-sm mb-2">
                                <i class="bi bi-box-arrow-up-right"></i> На Куфаре
                            </a>
                            <button class="btn @(item.IsInteresting ? "btn-warning" : "btn-outline-secondary") btn-sm"
                                    @onclick="() => ToggleInteresting(item.Id)">
                                <i class="bi @(item.IsInteresting ? "bi-star-fill" : "bi-star")"></i>
                                @(item.IsInteresting ? "В избранном" : "В избранное")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (result.TotalPages > 1)
{
    <nav class="pagination-container">
        <ul class="pagination">
            <li class="page-item @(result.Page == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => ChangePage(result.Page - 1)">Назад</button>
            </li>
            
            @for (int i = Math.Max(1, result.Page - 2); i <= Math.Min(result.TotalPages, result.Page + 2); i++)
            {
                var pageNum = i;
                <li class="page-item @(result.Page == pageNum ? "active" : "")">
                    <button class="page-link" @onclick="() => ChangePage(pageNum)">@pageNum</button>
                </li>
            }

            <li class="page-item @(result.Page == result.TotalPages ? "disabled" : "")">
                <button class="page-link" @onclick="() => ChangePage(result.Page + 1)">Вперед</button>
            </li>
        </ul>
    </nav>
}

@code {
    private PagedResult<Listing> result = new();
    private List<string> districts = new();
    private ListingFilter filter = new();

    protected override async Task OnInitializedAsync()
    {
        districts = await ListingService.GetDistrictsAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        result = await ListingService.GetListingsAsync(filter);
        StateHasChanged();
    }

    private async Task ApplyFilter()
    {
        filter.Page = 1;
        await LoadData();
    }

    private async Task ChangePage(int p)
    {
        filter.Page = p;
        await LoadData();
        // Scroll to top would be nice here but Blazor requires JS Interop
    }

    private async Task ToggleInteresting(int id)
    {
        await ListingService.ToggleInterestingAsync(id);
        var item = result.Items.FirstOrDefault(l => l.Id == id);
        if (item != null) item.IsInteresting = !item.IsInteresting;
    }
}

