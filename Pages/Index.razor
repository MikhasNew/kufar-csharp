@page "/"
@using RealEstateMinsk.Models
@using RealEstateMinsk.Services

@implements IDisposable
@inject ListingService ListingService
@inject KufarScraper Scraper
@inject IConfiguration Configuration
@inject OsmPolygonUpdaterService PolygonUpdater
@inject UpdateProgressService ProgressService

<PageTitle>Минск Недвижимость - Обзор</PageTitle>

@if (ProgressService.IsActive)
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="border-radius: 12px; background: linear-gradient(to right, #ffffff, #f8f9fa);">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="d-flex align-items-center">
                            <div class="spinner-grow spinner-grow-sm text-primary me-2" role="status"></div>
                            <span class="fw-bold text-dark">
                                @ProgressService.Status
                                @if (!string.IsNullOrEmpty(ProgressService.Region))
                                {
                                    <span class="badge bg-soft-primary text-primary ms-2" style="background-color: #e7f1ff;">
                                        <i class="bi bi-geo-alt-fill"></i> @ProgressService.Region
                                    </span>
                                }
                            </span>
                        </div>
                        <div class="text-end">
                            @if (ProgressService.Page > 0)
                            {
                                <span class="badge bg-light text-dark me-2 border">
                                    Стр. @ProgressService.Page из @ProgressService.MaxPages
                                </span>
                            }
                            <span class="fw-bold text-primary">@((int)ProgressService.Progress)%</span>
                        </div>
                    </div>
                    <div class="progress" style="height: 8px; background-color: #e9ecef; border-radius: 4px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" 
                             role="progressbar" 
                             style="width: @(ProgressService.Progress)%; transition: width 0.5s ease-in-out;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row mb-4">
    <div class="col-12 d-flex align-items-center flex-wrap gap-2">
        <div class="d-flex align-items-center">
            <label for="maxPages" class="form-label mb-0 me-2 text-nowrap">
                <i class="bi bi-layers"></i> Страниц парсинга:
            </label>
            <input type="number"
                   id="maxPages"
                   class="form-control"
                   style="width: 80px;"
                   min="1"
                   max="20"
                   step="1"
                   @bind="maxPages"
                   @bind:event="oninput" />
        </div>
        <button class="btn btn-primary" @onclick="RefreshData" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            <i class="bi bi-download"></i> @(isLoading ? "Загрузка..." : "Обновить данные")
        </button>
        <button class="btn btn-info text-white" @onclick="UpdateGeoPolygons" disabled="@isLoading">
            <i class="bi bi-map"></i> Обновить полигоны (OSM)
        </button>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <span class="ms-2 badge bg-success">@statusMessage</span>
        }
        <select class="form-select form-select-sm" style="width: auto;" @bind="selectedCategory" @bind:after="LoadData">
            <option value="">Все</option>
            <option value="Квартира">Квартиры</option>
            <option value="Дом">Дома</option>
        </select>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <h6 class="text-muted">Всего объявлений</h6>
            <h2>@stats.TotalListings</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <h6 class="text-muted">Средняя цена/м²</h6>
            <h2>$@stats.AvgPriceSqm.ToString("N0")</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <h6 class="text-muted">Средняя цена</h6>
            <h2>$@stats.AvgPrice.ToString("N0")</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <h6 class="text-muted">Районов</h6>
            <h2>@stats.ByDistrict.Count</h2>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="chart-container">
            <h5>По районам</h5>
            <table class="table table-sm">
                <thead><tr><th>Район</th><th>Кол-во</th><th>$/м²</th></tr></thead>
                <tbody>
                    @foreach (var d in stats.ByDistrict)
                    {
                        <tr><td>@d.Key</td><td>@d.Count</td><td>$@d.AvgPrice.ToString("N0")</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-md-6">
        <div class="chart-container">
            <h5>По типу дома</h5>
            <table class="table table-sm">
                <thead><tr><th>Тип</th><th>Кол-во</th><th>$/м²</th></tr></thead>
                <tbody>
                    @foreach (var t in stats.ByType)
                    {
                        <tr><td>@t.Key</td><td>@t.Count</td><td>$@t.AvgPrice.ToString("N0")</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<h4>Последние объявления</h4>
<div class="row">
    @foreach (var item in recentListings)
    {
        <div class="col-md-4">
            <ListingCard Listing="item" />
        </div>
    }
</div>

@code {
    private MarketStats stats = new();
    private List<Listing> recentListings = new();
    private bool isLoading = false;
    private string statusMessage = "";
    private int maxPages = 5;
    private string selectedCategory = "";

    protected override async Task OnInitializedAsync()
    {
        maxPages = Configuration.GetValue<int>("DataCollection:MaxPagesPerRun", 5);
        ProgressService.OnProgressUpdated += HandleProgressUpdate;
        await LoadData();
    }

    private void HandleProgressUpdate() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ProgressService.OnProgressUpdated -= HandleProgressUpdate;
    }

    private async Task LoadData()
    {
        stats = await ListingService.GetStatsAsync(selectedCategory == "Все" ? null : selectedCategory);
        var result = await ListingService.GetListingsAsync(new ListingFilter { PageSize = 6 });
        recentListings = result.Items;
    }

    private async Task RefreshData()
    {
        isLoading = true;
        statusMessage = "";
        try
        {
            int totalReceived = 0;
            int totalSaved = 0;
            var categories = new[] { "Квартира", "Дом" };
            var regions = new[] { ("7", "Минск"), ("5", "Минская область") };
            
            int totalSteps = categories.Length * regions.Length * maxPages;
            int currentStep = 0;

            ProgressService.Start("Запуск обновления данных...");

            foreach (var category in categories)
            {
                foreach (var (rgnId, rgnName) in regions)
                {
                    int pageNum = 0;
                    await foreach (var pageListings in Scraper.ScrapeEnumerableAsync(maxPages, category, rgnId))
                    {
                        pageNum++;
                        currentStep++;
                        
                        var progress = (currentStep * 100.0) / totalSteps;
                        ProgressService.Report(progress, $"Сбор: {category}", rgnName, pageNum, maxPages);

                        totalReceived += pageListings.Count;
                        var (newCount, updatedCount, savedListings) = await ListingService.SaveListingsAsync(pageListings);
                        totalSaved += newCount;
                        
                        // Если получили меньше чем ожидали или это конец страниц в Scraper
                        // (Scraper внутри уже обрабатывает регионы, но Index.razor об этом не знает детально)
                    }
                    // Scraper.ScrapeEnumerableAsync сам проходит по регионам rgnValues = { "7", "5" }
                    // ВАЖНО: Текущий Scraper.ScrapeEnumerableAsync делает цикл по rgnValues ВНУТРИ.
                    // Значит мой двойной цикл здесь может быть некорректным, если я вызываю его дважды.
                }
            }

            ProgressService.Report(100, "Обновление завершено");
            statusMessage = $"Получено {totalReceived}, сохранено {totalSaved}";
            await LoadData();
            await Task.Delay(1500);
            ProgressService.Reset();
        }
        catch (Exception ex)
        {
            statusMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SeedTestData()
    {
        isLoading = true;
        statusMessage = "";
        try
        {
            using var http = new HttpClient();
            // This might need a base address if it's Blazor Server. It's safer to use the service directly if possible, but keeping original logic.
            // Using placeholder HTTP call to existing endpoint
            var response = await http.PostAsJsonAsync("http://localhost:5000/api/seed", new { });
            statusMessage = "Готово";
            await LoadData();
        }
        catch (Exception ex)
        {
            statusMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateGeoPolygons()
    {
        isLoading = true;
        statusMessage = "Загрузка полигонов из OSM...";
        StateHasChanged(); // Force UI update to show loading status

        try
        {
            var path = System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "minsk_polygons.json");
            await PolygonUpdater.UpdatePolygonsAsync(path);
            statusMessage = "Полигоны успешно обновлены!";
        }
        catch (Exception ex)
        {
            statusMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private record SeedResult(string Message);
}