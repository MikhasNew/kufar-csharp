@inherits LayoutComponentBase

<PageTitle>Минск Недвижимость</PageTitle>

<div class="app-container">
    <header class="app-header">
        <div class="header-content">
            <div class="logo">
                <i class="bi bi-house-door-fill"></i>
                <span>Минск Недвижимость</span>
            </div>
            
            <nav class="nav-tabs">
                <NavLink class="nav-tab" href="" Match="NavLinkMatch.All">
                    <i class="bi bi-speedometer2"></i> Обзор
                </NavLink>
                <NavLink class="nav-tab" href="listings">
                    <i class="bi bi-list-ul"></i> Объявления
                </NavLink>
                <NavLink class="nav-tab" href="investment">
                    <i class="bi bi-graph-up-arrow"></i> Инвестиции
                </NavLink>
                <NavLink class="nav-tab" href="interesting">
                    <i class="bi bi-star-fill"></i> Избранное
                </NavLink>
                <NavLink class="nav-tab" href="stats">
                    <i class="bi bi-bar-chart-fill"></i> Статистика
                </NavLink>
                <NavLink class="nav-tab" href="map">
                    <i class="bi bi-map"></i> Карта
                </NavLink>
            </nav>
        </div>
    </header>

    <main class="app-main">
        <div class="content-wrapper">
            @Body
        </div>
    </main>
</div>

<style>
:root {
    --primary: #3498db;
    --primary-dark: #2980b9;
    --bg-light: #f8fafc;
    --text-main: #1e293b;
    --text-muted: #64748b;
    --glass-bg: rgba(255, 255, 255, 0.8);
    --glass-border: rgba(255, 255, 255, 0.3);
}

body {
    background-color: var(--bg-light);
    color: var(--text-main);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    margin: 0;
}

.app-container {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

.app-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 70px;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--glass-border);
    z-index: 1000;
    display: flex;
    align-items: center;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
}

.header-content {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 24px;
}

.logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--text-main);
}

.logo i {
    color: var(--primary);
    font-size: 1.5rem;
}

.nav-tabs {
    display: flex;
    gap: 8px;
}

.nav-tab {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 8px;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.2s ease;
}

.nav-tab i {
    font-size: 1.1rem;
}

.nav-tab:hover {
    background: rgba(0, 0, 0, 0.04);
    color: var(--text-main);
}

.nav-tab.active {
    background: rgba(52, 152, 219, 0.1);
    color: var(--primary);
}

.app-main {
    margin-top: 70px;
    padding: 32px 0;
}

.content-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
}

/* Переопределение стилей карт из старого шаблона для консистентности */
.stat-card, .listing-card, .chart-container {
    background: white;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    border: 1px solid #f1f5f9;
    margin-bottom: 24px;
}

.listing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
}

.price-tag {
    font-size: 1.75rem;
    font-weight: 800;
    color: #059669;
}

.badge {
    padding: 6px 12px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.025em;
}

.badge-type { background: #e0f2fe; color: #0369a1; }
.badge-district { background: #f3e8ff; color: #7e22ce; }

</style>